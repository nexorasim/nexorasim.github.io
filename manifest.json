      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "shortcuts": [
    {
      "name": "IoT Dashboard",
      "short_name": "Dashboard",
      "description": "Real-time IoT device monitoring and analytics",
      "url": "/#iot-dashboard",
      "icons": [
        {
          "src": "/icons/shortcut-dashboard.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Features",
      "short_name": "Features",
      "description": "25 premium IoT eSIM features with live telemetry",
      "url": "/#features",
      "icons": [
        {
          "src": "/icons/shortcut-features.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Architecture",
      "short_name": "Architecture",
      "description": "Azure IoT Hub and Digital Twins architecture",
      "url": "/#architecture",
      "icons": [
        {
          "src": "/icons/shortcut-architecture.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Enterprise",
      "short_name": "Enterprise",
      "description": "Enterprise IoT solutions and integrations",
      "url": "/enterprise",
      "icons": [
        {
          "src": "/icons/shortcut-enterprise.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-home-iot.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "NexoraSIM IoT Home Page - Desktop with 3D Visualization"
    },
    {
      "src": "/screenshots/mobile-home-iot.png",
      "sizes": "390x844",
      "type": "image/png",
      "platform": "narrow",
      "label": "NexoraSIM IoT Home Page - Mobile with Touch Interactions"
    },
    {
      "src": "/screenshots/iot-dashboard-live.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Live IoT Dashboard with Real-time Telemetry"
    },
    {
      "src": "/screenshots/features-3d-iot.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Interactive 3D IoT Features Grid"
    },
    {
      "src": "/screenshots/architecture-diagram.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Azure IoT Hub Architecture Visualization"
    }
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://nexorasim.github.io/manifest.json"
    },
    {
      "platform": "windows",
      "url": "ms-windows-store://pdp/?productid=NexoraSIMIoT"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "capture_links": "existing-client-navigate",
  "protocol_handlers": [
    {
      "protocol": "nexorasim",
      "url": "/?protocol=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/json"]
        }
      ]
    }
  }
}