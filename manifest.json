{
  "name": "NexoraSIM IoT Entertainment Server",
  "short_name": "NexoraSIM IoT",
  "description": "Premium IoT eSIM Entertainment Server with Azure IoT Hub integration and real-time telemetry",
  "version": "3.0.0",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#00D1FF",
  "background_color": "#F5F5F5",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["telecommunications", "iot", "business", "productivity", "entertainment"],
  "icons": [
